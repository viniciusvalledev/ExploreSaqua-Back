generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model avaliacoes {
  avaliacoes_id    Int          @id @default(autoincrement())
  comentario       String?      @db.Text
  nota             Float?
  usuario_id       Int?
  local_id         Int?
  parent_id        Int?
  usuarios         usuarios?    @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, map: "avaliacoes_ibfk_133")
  locais           locais?      @relation(fields: [local_id], references: [local_id], onDelete: Cascade, map: "avaliacoes_ibfk_134")
  avaliacoes       avaliacoes?  @relation("avaliacoesToavaliacoes", fields: [parent_id], references: [avaliacoes_id], onDelete: Cascade, map: "avaliacoes_ibfk_135")
  other_avaliacoes avaliacoes[] @relation("avaliacoesToavaliacoes")

  @@index([local_id], map: "local_id")
  @@index([parent_id], map: "parent_id")
  @@index([usuario_id], map: "usuario_id")
}

model contador_visualizacoes {
  id            Int    @id @default(autoincrement())
  identificador String @db.VarChar(255)
  visualizacoes Int    @default(0)
}

model imagens_local {
  id       Int     @id @default(autoincrement())
  url      String? @db.Text
  local_id Int?
  locais   locais? @relation(fields: [local_id], references: [local_id], onDelete: Cascade, map: "imagens_local_ibfk_1")

  @@index([local_id], map: "local_id")
}

model locais {
  local_id                 Int             @id @default(autoincrement())
  logoUrl                  String?         @db.Text
  tipo_cadastro            String?         @db.VarChar(255)
  indicador_nome           String?         @db.VarChar(255)
  indicador_contato        String?         @db.VarChar(255)
  indicador_email          String?         @db.VarChar(255)
  email_responsavel        String          @db.VarChar(255)
  contato_responsavel      String          @db.VarChar(255)
  alvara_funcionamento_url String?         @db.Text
  alvara_vigilancia_url    String?         @db.Text
  categoria                String?         @db.VarChar(255)
  nome_responsavel         String          @db.VarChar(255)
  cpf_responsavel          String          @db.VarChar(14)
  contato_local            String?         @db.VarChar(255)
  nome_local               String?         @db.VarChar(255)
  endereco                 String?         @db.VarChar(255)
  descricao                String?         @db.Text
  instagram                String?         @db.VarChar(255)
  status                   locais_status   @default(pendente_aprovacao)
  dados_atualizacao        Json?
  latitude                 Float?          @db.Float
  longitude                Float?          @db.Float
  createdAt                DateTime        @db.DateTime(0)
  updatedAt                DateTime        @db.DateTime(0)
  ativo                    Boolean?        @default(false)
  avaliacoes               avaliacoes[]
  imagens_local            imagens_local[]
}

model usuarios {
  usuario_id                  Int          @id @default(autoincrement())
  nome_completo_user          String       @db.VarChar(255)
  username                    String       @db.VarChar(255)
  email                       String       @db.VarChar(255)
  password                    String       @db.VarChar(255)
  enabled                     Boolean?     @default(false)
  confirmation_token          String?      @db.VarChar(255)
  reset_password_token        String?      @db.VarChar(255)
  reset_password_token_expiry DateTime?    @db.DateTime(0)
  unconfirmed_email           String?      @db.VarChar(255)
  email_change_token          String?      @db.VarChar(255)
  avaliacoes                  avaliacoes[]
}

enum locais_status {
  pendente_aprovacao
  ativo
  inativo
  pendente_atualizacao
  pendente_exclusao
  rejeitado
}
